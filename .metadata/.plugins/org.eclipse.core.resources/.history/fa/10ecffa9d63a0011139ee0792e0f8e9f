package recursion;

public class Reverse {

	public static String rev(String str) {
		if(str.isEmpty()){
			return str;
		}else {
			//return rev(str.substring(1)) + str.charAt(0);
			return str.charAt(0)+rev(str.substring(1));
		}    
		
		
	}
	public static void main(String[] args) {
		//java
		System.out.println(rev("java"));

	}

}
