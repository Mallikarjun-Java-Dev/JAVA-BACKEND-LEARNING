package jdbcnew.jdbc;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.Statement;
import java.util.Scanner;

public class Student {
public static void main(String[] args) throws ClassNotFoundException, Exception {
	Class.forName("com.mysql.cj.jdbc.Driver");
Connection c=DriverManager.getConnection("jdbc:mysql://localhost:3306/jspiders2","root","root");
Statement s=c.createStatement();
	System.out.println("database connected");
	
	//s.execute("create database jspiders2");
//System.out.println("database created");
	//s.execute("create table trainers(sid int primary key, sname varchar(40) not null, mobile long)");
	//System.out.println("table created");
	Scanner sc=new Scanner(System.in);
	
	PreparedStatement p1=c.prepareStatement("insert into trainsers values(?,?,?)");
	System.out.println("enter id");
	int sid=sc.nextInt();
	p1.setInt(1, sid);
	
	System.out.println("enter name");
	String sname1=sc.next();
	p1.setString(2, sname1);
	
	System.out.println("enter phone number");	
	long mobile=sc.nextLong();
	p1.setLong(3, mobile);
	
	p1.executeUpdate();
	System.out.println("values inserted");
	
	
	
	
}
}
