<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context"
    xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
    http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd">
    
   <!-- fully qualified class names including the controller package -->
   <bean class="setterInjectspringpro.controller.Engine" id="eng" />
   <bean class="setterInjectspringpro.controller.Car" id="c1">
      <!-- property name must match the JavaBean setter: setEngine -> name="engine" -->
      <property name="engine" ref="eng" />
   </bean>
   </bean>
   
</beans>
